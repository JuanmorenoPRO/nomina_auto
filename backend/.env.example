# Copiar a .env y completar. El .env real NUNCA se versiona (.gitignore).
# Desarrollo: SQLite. Producción: PostgreSQL.
DATABASE_URL=sqlite:///./nomina_dev.sqlite3
# DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/nomina

# Clave para firmar sesiones (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Orígenes permitidos para CORS (frontend)
CORS_ORIGINS=http://localhost:5173
